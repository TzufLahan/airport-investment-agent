# Copy this file to .env and add your key:  cp .env.example .env
# .env is gitignored — never commit a real key.
#
# The key is OPTIONAL. Without it, the agent runs its deterministic fallback
# (keyword intent parsing + templated answers); all scoring/ranking still works.
ANTHROPIC_API_KEY=your-key-here

# Optional: reliable web search for the autonomous agent (agent_app.py). Without it,
# web_search falls back to a keyless, best-effort DuckDuckGo scrape. Free tier:
# https://brave.com/search/api/
BRAVE_API_KEY=
